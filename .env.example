# OpenWeather API Key (Get one at openweathermap.org)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Internal API key for frontend-backend communication
API_AUTH_KEY=super-secret-key

# Rate limiting settings
RATE_LIMIT_CALLS=10
RATE_LIMIT_PERIOD=60

# Cost protection (requests per day)
MAX_DAILY_COST=50

# Server port
PORT=8000
